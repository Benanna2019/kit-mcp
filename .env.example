# Kit (ConvertKit) API key. Get one at https://app.kit.com/account/edit → Developer → API.
# This is the only required variable.
KIT_API_KEY=

# Transport mode. "http" (default) for Railway/hosted. "stdio" for local Claude Desktop.
MCP_TRANSPORT=http

# Port for HTTP mode. Railway injects this automatically; only set for local testing.
# PORT=3000
