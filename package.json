{
  "name": "kit-mcp",
  "version": "0.0.1",
  "description": "MCP server exposing Kit (ConvertKit) as tools for Cowork and other Claude clients. Built with Effect.",
  "private": false,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^17.4.2",
    "effect": "latest",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@effect/language-service": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
